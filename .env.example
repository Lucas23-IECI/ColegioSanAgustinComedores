# ─── Copia este archivo como .env y completa los valores ───────────────────
# cp .env.example .env

# Base de datos
DB_USER=colegio_user
DB_PASSWORD=cambia_esta_password
DB_NAME=MVP_Colaciones

# JWT — usa una cadena larga y aleatoria, nunca la compartas
JWT_SECRET=cambia_este_secreto_muy_largo_y_seguro

# CORS — URL desde donde acceden los navegadores al server
# Ejemplo: http://192.168.50.182  o  https://tudominio.cl
CORS_ORIGIN=http://192.168.50.182
